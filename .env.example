# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL=

# === HIVE COLLECTIVE RESONANCE CONFIG ===
ENABLE_HIVE_RESONANCE=
RESONANCE_NODE_NAME=Autodisco Hearth Node
RESONANCE_HUB_URL=

# --- Browser-safe (client-side) Supabase settings (prefixed with VITE_) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_AUTODISCO_SPACE_ID=

# --- Server-side secrets (no VITE_ prefix) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
AUTODISCO_SPACE_ID=
AUTODISCO_OWNER_EMAIL=
